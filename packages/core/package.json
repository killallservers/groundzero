{
  "name": "@groundzero/core",
  "module": "src/index.ts",
  "scripts": {
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "bun run db:generate && bun run db:migrate"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.103",
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/azure": "^3.0.64",
    "@ai-sdk/cohere": "^3.0.35",
    "@ai-sdk/google": "^3.0.71",
    "@ai-sdk/mistral": "^3.0.36",
    "@ai-sdk/openai": "^3.0.63",
    "ai": "^6.0.177",
    "drizzle-orm": "^0.45.2",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./db/*": "./src/db/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./pipeline/*": "./src/pipeline/*.ts"
  },
  "private": true,
  "type": "module"
}
