{
  "name": "groundzero",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --watch packages/api/src/index.ts",
    "typecheck": "tsgo -p .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci": "biome ci . && tsgo -p .",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun run packages/core/src/db/migrate.ts",
    "db:push": "bun run db:generate && bun run db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.13",
    "@typescript/native-preview": "^7.0.0-dev.20260510.1",
    "drizzle-kit": "^0.31.10"
  }
}
